# =============================================================================
# AI Security Monitoring Platform — Environment Configuration
# Copy this file to .env and fill in your values. NEVER commit .env to Git.
# =============================================================================

# --- Django ---
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Database (PostgreSQL) ---
POSTGRES_DB=security_monitoring
POSTGRES_USER=security_user
POSTGRES_PASSWORD=security_pass_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://security_user:security_pass_change_me@db:5432/security_monitoring

# --- Redis ---
REDIS_URL=redis://cache:6379/0
REDIS_CACHE_URL=redis://cache:6379/1
CELERY_BROKER_URL=redis://cache:6379/2
CELERY_RESULT_BACKEND=redis://cache:6379/3

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_LOGS=raw-logs
KAFKA_TOPIC_SCORED_EVENTS=scored-events
KAFKA_TOPIC_ALERTS=alerts
KAFKA_TOPIC_EDGE_EVENTS=edge-events
KAFKA_CONSUMER_GROUP_ID=security-monitoring-group

# --- ML Service ---
ML_SERVICE_URL=http://ml-service:8001
ML_SERVICE_API_KEY=ml-service-internal-key-change-me

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=security-monitoring
MLFLOW_ARTIFACT_STORE=./mlflow-artifacts

# --- Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#security-alerts
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
ALERT_EMAIL_RECIPIENTS=admin@example.com,security@example.com

# --- API Keys (for ingestion endpoints) ---
INGESTION_API_KEY=your-ingestion-api-key-change-me
ML_INFERENCE_API_KEY=your-ml-api-key-change-me

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- GCP (for production deployment) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ARTIFACT_REGISTRY=us-central1-docker.pkg.dev/your-project/security-monitoring
CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:security-monitoring-db
GCP_STORAGE_BUCKET=your-security-monitoring-bucket

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_password_change_me

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Edge / MQTT ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_EDGE=edge/security/events
MQTT_USERNAME=edge_user
MQTT_PASSWORD=edge_password_change_me

# --- Rate Limiting ---
INGESTION_RATE_LIMIT=100/minute
DASHBOARD_RATE_LIMIT=1000/minute

# --- Feature Engineering ---
FEATURE_WINDOW_MINUTES=5
ANOMALY_THRESHOLD_LOW=-0.2
ANOMALY_THRESHOLD_MEDIUM=-0.4
ANOMALY_THRESHOLD_HIGH=-0.7
